<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{project}} — Sprint Board</title>
<style>
  :root {
    --bg: #FAF8F5;
    --surface: #FFFFFF;
    --surface-2: #F3F0EB;
    --border: #E8E3DB;
    --text: #221D16;
    --muted: #6C6459;
    --faint: #9B9284;
    --accent: {{accent}};
    --accent-600: {{accent_600}};
    --accent-soft: {{accent_soft}};
    --done: #1C7A45;
    --done-soft: #E6F2EA;
    --active: var(--accent-600);
    --active-soft: var(--accent-soft);
    --planned: #857C6E;
    --planned-soft: #EEEAE3;
    --retired: #9B9284;
    --retired-soft: #F5F2ED;
    --sans: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    --shadow: 0 1px 2px rgba(34, 29, 22, 0.06);
  }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) {
      --bg: #161310;
      --surface: #1E1A16;
      --surface-2: #26211C;
      --border: #3A342C;
      --text: #F3EEE6;
      --muted: #B0A79A;
      --faint: #7A7166;
      --done-soft: #143524;
      --planned-soft: #2A2620;
      --retired-soft: #24201B;
      --shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
    }
  }
  :root[data-theme="light"] {
    --bg: #FAF8F5;
    --surface: #FFFFFF;
    --surface-2: #F3F0EB;
    --border: #E8E3DB;
    --text: #221D16;
    --muted: #6C6459;
    --faint: #9B9284;
    --done-soft: #E6F2EA;
    --planned-soft: #EEEAE3;
    --retired-soft: #F5F2ED;
    --shadow: 0 1px 2px rgba(34, 29, 22, 0.06);
  }
  :root[data-theme="dark"] {
    --bg: #161310;
    --surface: #1E1A16;
    --surface-2: #26211C;
    --border: #3A342C;
    --text: #F3EEE6;
    --muted: #B0A79A;
    --faint: #7A7166;
    --done-soft: #143524;
    --planned-soft: #2A2620;
    --retired-soft: #24201B;
    --shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    line-height: 1.45;
  }
  .tnum { font-variant-numeric: tabular-nums; }
  .wrap { max-width: 1100px; margin: 0 auto; padding: 28px 20px 64px; }
  header.top {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 20px;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  header.top h1 {
    margin: 0;
    font-size: 1.55rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .meta {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 0.92rem;
  }
  #themeToggle {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    border-radius: 8px;
    padding: 8px 12px;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
  }
  #themeToggle:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .tabs {
    display: flex;
    gap: 4px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 22px;
  }
  .tab {
    border: 0;
    background: none;
    font: inherit;
    font-weight: 600;
    color: var(--muted);
    padding: 10px 14px;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .tab[aria-selected="true"] {
    color: var(--accent-600);
    border-bottom-color: var(--accent);
  }
  .tab:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .panel[hidden] { display: none; }
  .kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 10px;
    margin-bottom: 18px;
  }
  .kpi {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 12px;
    box-shadow: var(--shadow);
  }
  .kpi .v {
    font-size: 1.45rem;
    font-weight: 700;
  }
  .kpi .l {
    color: var(--muted);
    font-size: 0.8rem;
    margin-top: 2px;
  }
  .spine {
    background: var(--surface-2);
    border-radius: 999px;
    height: 10px;
    overflow: hidden;
    display: flex;
    margin: 8px 0 6px;
  }
  .spine .seg-done { background: var(--done); height: 100%; }
  .spine .seg-active { background: var(--accent); height: 100%; }
  .spine-label { color: var(--muted); font-size: 0.85rem; margin-bottom: 22px; }
  .phase-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--faint);
    margin: 0 0 4px;
  }
  .phase-title { margin: 0 0 4px; font-size: 1.2rem; }
  .phase-note { margin: 0 0 14px; color: var(--muted); font-size: 0.9rem; }
  .sprint-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
    margin-bottom: 28px;
  }
  .sprint-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px;
    box-shadow: var(--shadow);
  }
  .sprint-card.done { background: var(--surface-2); }
  .sprint-card.active {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent-soft);
  }
  .sprint-card .id {
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .sprint-card h3 {
    margin: 8px 0 6px;
    font-size: 1.02rem;
  }
  .sprint-card p {
    margin: 0;
    color: var(--muted);
    font-size: 0.88rem;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
  .tag {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--muted);
    background: var(--surface-2);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 99px;
  }
  .pill.done { background: var(--done-soft); color: var(--done); }
  .pill.active { background: var(--active-soft); color: var(--active); }
  .pill.planned { background: var(--planned-soft); color: var(--planned); }
  .pill.retired { background: var(--retired-soft); color: var(--retired); }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
  }
  .pill.active .dot {
    animation: pulse 1.4s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.85); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pill.active .dot { animation: none !important; }
  }
  .sprint-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 16px;
    margin-bottom: 14px;
    box-shadow: var(--shadow);
  }
  .sprint-block-head {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    align-items: center;
    margin-bottom: 12px;
  }
  .sprint-block-head h3 { margin: 0; font-size: 1.05rem; }
  .count { color: var(--muted); font-size: 0.85rem; margin-left: auto; }
  .task-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 8px;
  }
  .tk {
    display: grid;
    grid-template-columns: 18px 1fr;
    gap: 8px;
    align-items: start;
    padding: 8px 10px;
    border-radius: 10px;
    background: var(--surface-2);
  }
  .tk.retired { opacity: 0.55; }
  .box {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1.5px solid var(--planned);
    margin-top: 2px;
  }
  .tk.done .box {
    background: var(--done);
    border-color: var(--done);
  }
  .tk.active .box {
    border-color: var(--accent-600);
    box-shadow: inset 0 0 0 3px var(--surface-2), inset 0 0 0 5px var(--accent-600);
  }
  .ref {
    font-weight: 700;
    font-size: 0.78rem;
    color: var(--muted);
  }
  .tk-title { font-size: 0.92rem; }
  .raw {
    display: block;
    color: var(--faint);
    font-size: 0.75rem;
    margin-top: 2px;
  }
  .empty {
    border: 1px dashed var(--border);
    border-radius: 12px;
    padding: 28px;
    color: var(--muted);
    text-align: center;
  }
  .chart-row {
    display: grid;
    grid-template-columns: 88px 1fr 48px;
    gap: 10px;
    align-items: center;
    margin: 8px 0;
  }
  .bars {
    display: flex;
    height: 18px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--surface-2);
  }
  .bars .d { background: var(--done); height: 100%; }
  .bars .a { background: var(--accent); height: 100%; }
  .bars .p { background: var(--planned); height: 100%; }
  .hbar {
    height: 10px;
    border-radius: 999px;
    background: var(--surface-2);
    overflow: hidden;
  }
  .hbar > i {
    display: block;
    height: 100%;
    background: var(--accent-600);
  }
  .hbar.tone-done > i { background: var(--done); }
  .hbar.tone-active > i { background: var(--accent); }
  .hbar.tone-planned > i { background: var(--planned); }
  .section-label {
    margin: 22px 0 8px;
    font-size: 0.95rem;
    font-weight: 700;
  }
  footer.snap {
    margin-top: 36px;
    color: var(--faint);
    font-size: 0.8rem;
  }
</style>
</head>
<body>
  <div class="wrap">
    <header class="top">
      <div>
        <h1>{{project}}</h1>
        <p class="meta">Sprint board · snapshot {{snapshot_iso}} · derived from <code>conclave/</code></p>
      </div>
      <button type="button" id="themeToggle" aria-label="Toggle color theme">Theme</button>
    </header>

    <div class="tabs" role="tablist" aria-label="Sprint board views">
      <button class="tab" role="tab" id="tab-roadmap" aria-controls="p-roadmap" aria-selected="true">Roadmap</button>
      <button class="tab" role="tab" id="tab-tareas" aria-controls="p-tareas" aria-selected="false">Tasks</button>
      <button class="tab" role="tab" id="tab-analiticas" aria-controls="p-analiticas" aria-selected="false">Analytics</button>
    </div>

    <section class="panel" id="p-roadmap" role="tabpanel" aria-labelledby="tab-roadmap">
      <!-- {{KPI_TILES}} -->
      <!-- {{SPINE}} -->
      <!-- {{PHASE_SECTIONS}} -->
    </section>

    <section class="panel" id="p-tareas" role="tabpanel" aria-labelledby="tab-tareas" hidden>
      <!-- {{TASK_BLOCKS}} -->
    </section>

    <section class="panel" id="p-analiticas" role="tabpanel" aria-labelledby="tab-analiticas" hidden>
      <!-- {{ANALYTICS}} -->
    </section>

    <footer class="snap">Generated by <code>/conclave-sprint-board</code>. Re-run the command to refresh. Source of truth remains <code>conclave/</code>.</footer>
  </div>
  <script>
  (function () {
    var tabs = [].slice.call(document.querySelectorAll(".tab"));
    var map = {
      "tab-roadmap": "p-roadmap",
      "tab-tareas": "p-tareas",
      "tab-analiticas": "p-analiticas"
    };
    function sel(t) {
      tabs.forEach(function (x) {
        var on = x === t;
        x.setAttribute("aria-selected", on);
        document.getElementById(map[x.id]).hidden = !on;
      });
      t.focus();
    }
    tabs.forEach(function (t, i) {
      t.onclick = function () { sel(t); };
      t.onkeydown = function (e) {
        if (e.key === "ArrowRight") {
          e.preventDefault();
          sel(tabs[(i + 1) % tabs.length]);
        }
        if (e.key === "ArrowLeft") {
          e.preventDefault();
          sel(tabs[(i - 1 + tabs.length) % tabs.length]);
        }
      };
    });
    var root = document.documentElement;
    var saved = null;
    try { saved = localStorage.getItem("sb-theme"); } catch (e) {}
    if (saved) root.setAttribute("data-theme", saved);
    document.getElementById("themeToggle").onclick = function () {
      var c = root.getAttribute("data-theme") ||
        (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      var n = c === "dark" ? "light" : "dark";
      root.setAttribute("data-theme", n);
      try { localStorage.setItem("sb-theme", n); } catch (e) {}
    };
  })();
  </script>
</body>
</html>
