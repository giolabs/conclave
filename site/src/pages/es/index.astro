---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import FeatureGrid from "../../components/FeatureGrid.astro";
import LoopTimeline from "../../components/LoopTimeline.astro";
import ProfileComparison from "../../components/ProfileComparison.astro";
import InstallBlock from "../../components/InstallBlock.astro";
import { useTranslations } from "../../i18n/utils";

const t = useTranslations("es");
---

<BaseLayout
  title="Conclave"
  description="Scrum para equipos con Claude Code. Seis subagents de IA se coordinan vía markdown plano commiteado a git. Open source, MIT licensed."
>
  <Hero />
  <FeatureGrid />
  <LoopTimeline />
  <ProfileComparison />

  <section class="relative border-t border-[--color-border]">
    <div class="mx-auto max-w-3xl px-4 py-20 sm:px-6 lg:px-8 lg:py-24">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-[--color-text] sm:text-4xl">
          {t("install.title")}
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-base text-[--color-text-muted]">{t("install.subtitle")}</p>
      </div>
      <div class="mt-10">
        <InstallBlock />
      </div>
    </div>
  </section>
</BaseLayout>
