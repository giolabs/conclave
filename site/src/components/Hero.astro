---
import { getLangFromUrl, useTranslations, withBase } from "../i18n/utils";
import TerminalMockup from "./TerminalMockup.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
---

<section class="relative overflow-hidden">
  <!-- background gradient orbs -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div
      class="absolute -top-40 left-1/2 h-[40rem] w-[60rem] -translate-x-1/2 rounded-full bg-[--color-accent-500] opacity-[0.08] blur-3xl"
    >
    </div>
    <div
      class="absolute -top-20 right-0 h-[20rem] w-[30rem] rounded-full bg-[--color-accent-700] opacity-[0.10] blur-3xl"
    >
    </div>
  </div>
  <!-- grid backdrop -->
  <div
    class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.025)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.025)_1px,transparent_1px)] bg-[size:40px_40px]"
    style="mask-image: radial-gradient(ellipse at top, black 30%, transparent 75%); -webkit-mask-image: radial-gradient(ellipse at top, black 30%, transparent 75%);"
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-4 pb-16 pt-16 sm:px-6 sm:pb-20 sm:pt-20 lg:px-8 lg:pb-28 lg:pt-28">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-[1.1fr_1fr]">
      <div>
        <div
          class="inline-flex items-center gap-2 rounded-full border border-[--color-border-strong] bg-[--color-bg-elevated]/60 px-3 py-1 text-xs font-medium text-[--color-text-muted] backdrop-blur"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[--color-accent-400] opacity-60"
            ></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-[--color-accent-400]"></span>
          </span>
          {t("hero.eyebrow")}
        </div>
        <h1
          class="mt-6 text-balance text-5xl font-bold leading-[1.05] tracking-tight text-[--color-text] sm:text-6xl lg:text-7xl"
        >
          <span class="block">{t("hero.title.line1")}</span>
          <span
            class="block bg-gradient-to-r from-[--color-accent-300] via-[--color-accent-400] to-[--color-accent-600] bg-clip-text text-transparent"
          >
            {t("hero.title.line2")}
          </span>
        </h1>
        <p class="mt-6 max-w-xl text-base leading-relaxed text-[--color-text-muted] sm:text-lg">
          {t("hero.subtitle")}
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href={withBase(`/${lang}/docs/getting-started/`, base)} class="btn-primary">
            {t("hero.cta.docs")}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                clip-rule="evenodd"
              />
            </svg>
          </a>
          <a
            href="https://github.com/lucasgio/conclave"
            target="_blank"
            rel="noopener"
            class="btn-secondary"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z"
              />
            </svg>
            {t("hero.cta.github")}
          </a>
        </div>
        <div class="mt-6 flex items-center gap-4 text-xs text-[--color-text-subtle]">
          <span class="inline-flex items-center gap-1.5">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-[--color-success]"></span>
            v0.1.0
          </span>
          <span>·</span>
          <span>MIT licensed</span>
          <span>·</span>
          <span>EN / ES</span>
        </div>
      </div>
      <div class="lg:max-w-none">
        <TerminalMockup />
      </div>
    </div>
  </div>
</section>
