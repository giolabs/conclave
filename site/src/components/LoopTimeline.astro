---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const steps = [
  { key: "step1", cmd: "/conclave-init", role: "PM·TL" },
  { key: "step2", cmd: "/conclave-spec", role: "PM·TL" },
  { key: "step3", cmd: "/conclave-planning", role: "SM·PM·TL" },
  { key: "step4", cmd: "/conclave-dev", role: "Dev" },
  { key: "step5", cmd: "/conclave-qa", role: "QA" },
  { key: "step6", cmd: "/conclave-pr-review", role: "TL" },
];
---

<section class="relative">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-[--color-text] sm:text-4xl">
        {t("loop.title")}
      </h2>
      <p class="mt-4 text-base text-[--color-text-muted]">{t("loop.subtitle")}</p>
    </div>

    <div class="mt-14">
      <ol class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
        {steps.map((step, idx) => (
          <li
            class="group relative flex flex-col gap-3 rounded-[--radius-card] border border-[--color-border] bg-[--color-bg-card] p-5 transition hover:border-[--color-accent-500]/40 hover:bg-[--color-bg-card]/80"
          >
            <div class="flex items-center justify-between">
              <span
                class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-[--color-bg-elevated] font-mono text-xs font-semibold text-[--color-accent-400] ring-1 ring-[--color-border]"
              >
                {idx + 1}
              </span>
              <span
                class="rounded-md bg-[--color-bg-elevated] px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-[--color-text-subtle] ring-1 ring-[--color-border]"
              >
                {step.role}
              </span>
            </div>
            <div>
              <div class="font-mono text-xs text-[--color-accent-300]">{step.cmd}</div>
              <h3 class="mt-1 text-sm font-semibold text-[--color-text]">
                {t(`loop.${step.key}.title` as any)}
              </h3>
            </div>
            <p class="text-xs leading-relaxed text-[--color-text-muted]">
              {t(`loop.${step.key}.body` as any)}
            </p>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
