---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const steps = [
  { num: "1", label: t("install.step1.label"), cmd: "claude plugin marketplace add lucasgio/conclave" },
  { num: "2", label: t("install.step2.label"), cmd: "claude plugin install conclave@conclave" },
];
---

<div class="space-y-4">
  {steps.map((step) => (
    <div class="group flex items-stretch gap-3 rounded-[--radius-card] border border-[--color-border] bg-[--color-bg-card] p-1">
      <div class="flex w-9 shrink-0 items-center justify-center rounded-l-md bg-[--color-bg-elevated] font-mono text-sm font-semibold text-[--color-accent-400]">
        {step.num}
      </div>
      <div class="flex flex-1 items-center justify-between gap-3 py-3 pr-3">
        <div class="flex flex-col gap-1 overflow-hidden">
          <span class="text-xs uppercase tracking-wider text-[--color-text-subtle]">{step.label}</span>
          <code class="overflow-x-auto whitespace-nowrap font-mono text-sm text-[--color-text]">{step.cmd}</code>
        </div>
        <button
          type="button"
          data-copy={step.cmd}
          class="copy-btn group/btn shrink-0 rounded-md border border-[--color-border-strong] p-2 text-[--color-text-muted] transition hover:border-[--color-text-muted] hover:bg-[--color-bg-elevated] hover:text-[--color-text]"
          aria-label="Copy command"
        >
          <svg
            data-icon="copy"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="h-4 w-4 group-[.is-copied]/btn:hidden"
            aria-hidden="true"
          >
            <path d="M7 3a3 3 0 00-3 3v9a3 3 0 003 3h6a3 3 0 003-3V6a3 3 0 00-3-3H7zm0 2h6a1 1 0 011 1v9a1 1 0 01-1 1H7a1 1 0 01-1-1V6a1 1 0 011-1z" />
          </svg>
          <svg
            data-icon="check"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="hidden h-4 w-4 text-[--color-success] group-[.is-copied]/btn:block"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
            />
          </svg>
        </button>
      </div>
    </div>
  ))}
  <div class="rounded-[--radius-card] border border-dashed border-[--color-border-strong] bg-transparent p-4">
    <div class="text-xs uppercase tracking-wider text-[--color-text-subtle]">{t("install.step3.label")}</div>
    <p class="mt-1 text-sm text-[--color-text-muted]">{t("install.step3.body")}</p>
  </div>
</div>

<script>
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement | null;
    const btn = target?.closest<HTMLButtonElement>("[data-copy]");
    if (!btn) return;
    const cmd = btn.dataset.copy ?? "";
    void navigator.clipboard.writeText(cmd).then(() => {
      btn.classList.add("is-copied");
      window.setTimeout(() => btn.classList.remove("is-copied"), 1500);
    });
  });
</script>
