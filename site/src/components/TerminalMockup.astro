---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const promptLabel = lang === "es" ? "tu-repo" : "your-repo";
---

<div
  class="relative rounded-[--radius-card] border border-[--color-border] bg-[--color-bg-card] shadow-2xl shadow-black/50"
>
  <!-- glow behind the card -->
  <div
    class="pointer-events-none absolute -inset-1 -z-10 rounded-[--radius-card] bg-gradient-to-br from-[--color-accent-500]/30 via-transparent to-[--color-accent-700]/20 blur-xl"
  >
  </div>

  <!-- titlebar -->
  <div class="flex items-center gap-2 border-b border-[--color-border] px-4 py-2.5">
    <div class="flex items-center gap-1.5">
      <div class="h-2.5 w-2.5 rounded-full bg-[#ff5f56]"></div>
      <div class="h-2.5 w-2.5 rounded-full bg-[#ffbd2e]"></div>
      <div class="h-2.5 w-2.5 rounded-full bg-[#27c93f]"></div>
    </div>
    <div class="ml-2 font-mono text-xs text-[--color-text-subtle]">claude · {promptLabel}</div>
  </div>

  <!-- body -->
  <div class="space-y-2 px-5 py-5 font-mono text-[13px] leading-relaxed">
    <div class="flex gap-2">
      <span class="text-[--color-accent-400]">›</span>
      <span class="text-[--color-text]">/conclave-spec</span>
      <span class="text-[--color-text-muted]">"REST API for task management with JWT auth"</span>
    </div>
    <div class="pl-4 text-[--color-text-subtle]">
      <div class="opacity-80">→ snapshotting CLAUDE.md, skills, rules into <span class="text-[--color-accent-300]">conclave/context/</span></div>
      <div class="opacity-80">→ asking 4 clarifying questions...</div>
    </div>
    <div class="flex gap-2 pl-4 pt-1">
      <span class="text-[--color-accent-400]">⊕</span>
      <span class="text-[--color-text]">Spawning <span class="text-[--color-accent-300]">tech-lead</span> + <span class="text-[--color-accent-300]">product-manager</span> in parallel</span>
    </div>
    <div class="space-y-1 pl-7 text-[--color-text-muted]">
      <div class="flex items-center gap-2">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[--color-success]"></span>
        TL · architecture.md · 3 ADRs · mermaid component diagram
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[--color-success]"></span>
        PM · backlog.md · 11 stories · Gherkin acceptance criteria
      </div>
    </div>
    <div class="flex gap-2 pl-4 pt-1">
      <span class="text-[--color-accent-400]">✓</span>
      <span class="text-[--color-text]">Wrote <span class="text-[--color-accent-300]">conclave/sprints/SPRINT-001/</span></span>
    </div>
    <div class="pl-7 text-[--color-text-subtle]">
      spec.md · 5 stories · 5 acceptance files
    </div>
    <div class="mt-2 flex items-center gap-2 pl-4 text-xs text-[--color-text-subtle]">
      <span class="inline-flex items-center gap-1 rounded-md border border-[--color-border-strong] px-2 py-0.5">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[--color-warning]"></span>
        next: /conclave-planning
      </span>
    </div>
  </div>
</div>
