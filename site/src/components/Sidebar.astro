---
import { getCollection } from "astro:content";
import { getLangFromUrl, withBase } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL;
const entries = (await getCollection("docs")).filter((e) => e.data.lang === lang);

const groups = {
  overview: entries.filter((e) => e.data.category === "overview").sort((a, b) => a.data.order - b.data.order),
  methodology: entries.filter((e) => e.data.category === "methodology").sort((a, b) => a.data.order - b.data.order),
  commands: entries.filter((e) => e.data.category === "commands").sort((a, b) => a.data.order - b.data.order),
};

const labels = lang === "es"
  ? { overview: "Empezar", methodology: "Metodología", commands: "Comandos" }
  : { overview: "Get started", methodology: "Methodology", commands: "Commands" };

const currentPath = Astro.url.pathname.replace(/\/$/, "");
---

<nav class="space-y-6 pr-2 text-sm">
  {(["overview", "methodology", "commands"] as const).map((group) => (
    <div>
      <div class="mb-2 text-xs font-semibold uppercase tracking-wider text-[--color-text-subtle]">
        {labels[group]}
      </div>
      <ul class="space-y-1 border-l border-[--color-border]">
        {groups[group].map((entry) => {
          // entry.slug looks like "en/getting-started" or "en/commands/init"
          const docSlug = entry.slug.replace(new RegExp(`^${lang}/`), "");
          const href = withBase(`/${lang}/docs/${docSlug}/`, base);
          const isActive = currentPath === href.replace(/\/$/, "");
          return (
            <li>
              <a
                href={href}
                class:list={[
                  "block border-l-2 py-1.5 pl-3 transition",
                  isActive
                    ? "border-[--color-accent-500] text-[--color-accent-300]"
                    : "border-transparent text-[--color-text-muted] hover:border-[--color-text-muted] hover:text-[--color-text]",
                ]}
              >
                {entry.data.title}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  ))}
</nav>
