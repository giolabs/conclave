---
import { getLangFromUrl, useTranslations, withBase } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
const year = 2026;
---

<footer class="border-t border-[--color-border] bg-[--color-bg]">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2.5">
          <div
            class="flex h-7 w-7 items-center justify-center rounded-md bg-gradient-to-br from-[--color-accent-500] to-[--color-accent-700]"
          >
            <span class="font-mono text-xs font-bold text-white">C</span>
          </div>
          <span class="font-semibold tracking-tight">Conclave</span>
        </div>
        <p class="mt-3 max-w-md text-sm text-[--color-text-muted]">
          {t("footer.tagline")}
        </p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-[--color-text]">{t("footer.docs")}</h4>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a
              href={withBase(`/${lang}/docs/getting-started/`, base)}
              class="text-[--color-text-muted] hover:text-[--color-text]"
            >
              Getting started
            </a>
          </li>
          <li>
            <a
              href={withBase(`/${lang}/docs/methodology/`, base)}
              class="text-[--color-text-muted] hover:text-[--color-text]"
            >
              {t("nav.methodology")}
            </a>
          </li>
          <li>
            <a
              href={withBase(`/${lang}/docs/profiles/`, base)}
              class="text-[--color-text-muted] hover:text-[--color-text]"
            >
              Profiles
            </a>
          </li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-[--color-text]">Project</h4>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a
              href="https://github.com/lucasgio/conclave"
              target="_blank"
              rel="noopener"
              class="text-[--color-text-muted] hover:text-[--color-text]"
            >
              {t("footer.github")}
            </a>
          </li>
          <li>
            <a
              href="https://github.com/lucasgio/conclave/blob/main/LICENSE"
              target="_blank"
              rel="noopener"
              class="text-[--color-text-muted] hover:text-[--color-text]"
            >
              {t("footer.license")} · MIT
            </a>
          </li>
          <li class="text-[--color-text-subtle]">
            {t("footer.version")} 0.1.0
          </li>
        </ul>
      </div>
    </div>
    <div
      class="mt-10 border-t border-[--color-border] pt-6 text-xs text-[--color-text-subtle]"
    >
      © {year} Conclave contributors.
    </div>
  </div>
</footer>
