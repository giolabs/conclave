---
import { getLangFromUrl, localizedPath } from "../i18n/utils";
import { ui, languages } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL;
const other = (lang === "en" ? "es" : "en") as keyof typeof languages;
const otherUrl = localizedPath(Astro.url, other, base);
---

<a
  href={otherUrl}
  class="inline-flex items-center gap-1.5 rounded-md border border-[--color-border-strong] px-2.5 py-1.5 text-xs font-medium text-[--color-text-muted] transition hover:border-[--color-text-muted] hover:bg-[--color-bg-elevated] hover:text-[--color-text]"
  aria-label={`${ui[lang]["lang.switchTo"]} ${languages[other]}`}
  title={`${ui[lang]["lang.switchTo"]} ${languages[other]}`}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 20 20"
    fill="currentColor"
    class="h-3.5 w-3.5"
  >
    <path
      fill-rule="evenodd"
      d="M10 1a9 9 0 100 18 9 9 0 000-18zM7.5 10a17.85 17.85 0 011.32-6.674C9.155 2.553 9.59 2 10 2c.41 0 .845.553 1.18 1.326A17.85 17.85 0 0112.5 10a17.85 17.85 0 01-1.32 6.674C10.845 17.447 10.41 18 10 18s-.845-.553-1.18-1.326A17.85 17.85 0 017.5 10zm-3.34-2A8.013 8.013 0 016.97 4.34a13.4 13.4 0 00-.97 3.66H4.16zm-.16 2c0 .56.06 1.11.17 1.66H6c.07.96.21 1.86.41 2.68A8.013 8.013 0 014.16 12H6c-.07-.66-.1-1.33-.1-2 0-.67.03-1.34.1-2H4.17zm9.66-2A13.4 13.4 0 0013.03 4.34 8.013 8.013 0 0115.84 8h-2.01zM14 10c0 .67-.03 1.34-.1 2h1.94a8.013 8.013 0 01-.4-1.66c.11-.55.17-1.1.17-1.66 0-.56-.06-1.11-.17-1.66.1-.55.16-1.1.16-1.66H14c.07.66.1 1.33.1 2zm-2.83 5.66A13.4 13.4 0 0013.03 12h2.81a8.013 8.013 0 01-2.81 3.66h-1.86zM6.97 15.66A8.013 8.013 0 014.16 12H6c.16 1.32.49 2.55.97 3.66z"
      clip-rule="evenodd"></path>
  </svg>
  {other.toUpperCase()}
</a>
