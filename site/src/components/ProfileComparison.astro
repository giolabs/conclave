---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// rows: [ceremony key, lean state, full-scrum state]
type Cell = "always" | "required" | "optional";
const rows: { key: string; lean: Cell; full: Cell }[] = [
  { key: "planning", lean: "always", full: "always" },
  { key: "qa", lean: "always", full: "always" },
  { key: "standup", lean: "optional", full: "required" },
  { key: "grooming", lean: "optional", full: "required" },
  { key: "review", lean: "optional", full: "required" },
  { key: "sprintreview", lean: "optional", full: "required" },
  { key: "retro", lean: "optional", full: "required" },
];

const cellClass = (state: Cell) =>
  state === "always"
    ? "border-[--color-success]/30 bg-[--color-success]/10 text-[--color-success]"
    : state === "required"
      ? "border-[--color-accent-500]/30 bg-[--color-accent-500]/10 text-[--color-accent-300]"
      : "border-[--color-border] bg-[--color-bg-elevated] text-[--color-text-subtle]";

const cellLabel = (state: Cell) =>
  state === "always" ? t("profiles.always") : state === "required" ? t("profiles.required") : t("profiles.optional");
---

<section class="relative border-t border-[--color-border]">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-[--color-text] sm:text-4xl">
        {t("profiles.title")}
      </h2>
      <p class="mt-4 text-base text-[--color-text-muted]">{t("profiles.subtitle")}</p>
    </div>

    <div class="mt-14 overflow-hidden rounded-[--radius-card] border border-[--color-border] bg-[--color-bg-card]">
      <div class="grid grid-cols-1 gap-px bg-[--color-border] sm:grid-cols-3">
        <div class="bg-[--color-bg-card] p-6">
          <div class="text-xs uppercase tracking-wider text-[--color-text-subtle]">profile</div>
          <div class="mt-1 text-lg font-semibold text-[--color-text]">{t("profiles.lean")}</div>
          <p class="mt-2 text-sm text-[--color-text-muted]">{t("profiles.lean.body")}</p>
        </div>
        <div class="bg-[--color-bg-card] p-6">
          <div class="text-xs uppercase tracking-wider text-[--color-text-subtle]">profile</div>
          <div class="mt-1 text-lg font-semibold text-[--color-text]">{t("profiles.full")}</div>
          <p class="mt-2 text-sm text-[--color-text-muted]">{t("profiles.full.body")}</p>
        </div>
        <div class="bg-[--color-bg-card] p-6">
          <div class="text-xs uppercase tracking-wider text-[--color-text-subtle]">profile</div>
          <div class="mt-1 text-lg font-semibold text-[--color-text]">{t("profiles.custom")}</div>
          <p class="mt-2 text-sm text-[--color-text-muted]">{t("profiles.custom.body")}</p>
        </div>
      </div>

      <div class="overflow-x-auto border-t border-[--color-border]">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[--color-border] bg-[--color-bg-elevated]/50">
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-[--color-text-subtle]">
                {t("profiles.ceremony")}
              </th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-[--color-text-subtle]">
                {t("profiles.lean")}
              </th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-[--color-text-subtle]">
                {t("profiles.full")}
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[--color-border]">
            {rows.map((row) => (
              <tr>
                <td class="px-4 py-3 text-[--color-text]">{t(`profiles.cell.${row.key}` as any)}</td>
                <td class="px-4 py-3">
                  <span
                    class:list={[
                      "inline-flex items-center gap-1.5 rounded-md border px-2.5 py-1 text-xs font-medium",
                      cellClass(row.lean),
                    ]}
                  >
                    {cellLabel(row.lean)}
                  </span>
                </td>
                <td class="px-4 py-3">
                  <span
                    class:list={[
                      "inline-flex items-center gap-1.5 rounded-md border px-2.5 py-1 text-xs font-medium",
                      cellClass(row.full),
                    ]}
                  >
                    {cellLabel(row.full)}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
